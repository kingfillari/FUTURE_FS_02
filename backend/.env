# Server
PORT=5000

# Database (use your MongoDB connection string)
MONGO_URI=mongodb://localhost:27017/crm_db
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crm_db?retryWrites=true&w=majority

# JWT secret (change in production)
JWT_SECRET=your_super_strong_secret_key_change_this_in_production

# Optional: seed admin credentials
ADMIN_EMAIL=admin@crm.com
ADMIN_PASSWORD=admin123